{
  "name": "dcam",
  "description": "DeltaCAT Agent Memory \u2014 persistent memory across sessions",
  "mcpServers": {
    "dcam": {
      "command": "dcam",
      "args": [
        "serve"
      ],
      "type": "stdio"
    }
  },
  "tools": [
    "@builtin",
    "@dcam"
  ],
  "allowedTools": [
    "@dcam/*",
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "@*"
  ],
  "resources": [
    "file://AGENTS.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "command": "./hooks/dcam-pre-tool.sh"
      }
    ]
  }
}